{
  "type": "app",
  "name": "maps",
  "id": "ad3a9d16-e56f-48a9-a9ed-b906d5646e74",
  "title": "Maps",
  "minDHIS2Version": "2.40",
  "pluginType": "DASHBOARD",
  "viteConfigExtensions": {
    "optimizeDeps": {
      "exclude": [
        "@dhis2/maps-gl"
      ],
      "include": [
        "maplibre-gl",
        "fetch-jsonp",
        "lodash.throttle",
        "@mapbox/sphericalmercator",
        "@turf/area",
        "@turf/bbox",
        "@turf/buffer",
        "@turf/center-of-mass",
        "@turf/centroid",
        "@turf/circle",
        "@turf/jsts",
        "@turf/length",
        "comlink",
        "concaveman",
        "polylabel",
        "pretty-bytes",
        "suggestions",
        "uuid"
      ],
      "esbuildOptions": {
        "target": "es2022"
      }
    },
    "build": {
      "target": "es2022",
      "rollupOptions": {
        "output": {
          "manualChunks": {
            "maps-gl": [
              "@dhis2/maps-gl"
            ]
          }
        }
      }
    }
  },
  "coreApp": true,
  "dataStoreNamespace": "DHIS2_MAPS_APP_CORE",
  "version": "101.14.0",
  "author": {
    "name": "Bjørn Sandvik"
  },
  "description": "DHIS2 Maps",
  "entryPoints": {
    "app": "index.html",
    "plugin": "plugin.html"
  }
}
